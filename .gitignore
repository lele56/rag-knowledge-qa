.gradio/

# 数据
# 只保留示例测试文件，不保留评估结果和你的实际数据
data/*.json
!data/*.example.json
!data/test_question_example.json

# 测试文档（本地 PDF 不入库）
data/test_docs/

# 评估结果（每次评估生成，不要进 Git）
data/*_results.json

# 本地索引文件
data/doc_id_registry.json
!data/doc_id_registry.example.json

# 日志
*.log
*.log.*

