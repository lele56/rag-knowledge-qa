# ============================================================
# 知识库问答助手 - 环境变量配置模板
# 复制此文件为 .env 并填入你的真实凭证
# cp .env.example .env
# ============================================================

# ---------- Qdrant Cloud ----------
# 注册地址: https://cloud.qdrant.io
QDRANT_URL="https://xxxxx.us-west-1-0.aws.cloud.qdrant.io"
QDRANT_API_KEY="your-qdrant-api-key"

# ---------- Neo4j AuraDB ----------
# 注册地址: https://neo4j.com/cloud/aura/
NEO4J_URI="neo4j+s://xxxxx.databases.neo4j.io"
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD="your-neo4j-password"
NEO4J_DATABASE=neo4j

# ---------- LLM API (OpenAI 兼容协议) ----------
# 支持: OpenAI / DeepSeek / 通义千问 / 任意 OpenAI-compatible API
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ---------- 本地模型路径 ----------
# 嵌入模型（用于向量化文档和查询）
EMBEDDING_MODEL_PATH=./models/bge-small-zh
# 或使用 BGE-M3（多语言，效果更好但更慢）:
# EMBEDDING_MODEL_PATH=BAAI/bge-m3

# 重排序模型（CrossEncoder，提升检索精度，可选）
RERANKER_MODEL_PATH=BAAI/bge-reranker-v2-m3

# ---------- 检索策略 ----------
# simple     : 纯向量检索（最快）
# multi_query: LLM 生成多个查询变体（更全）
# hyde       : 生成假设性文档再检索（更准）
RETRIEVAL_STRATEGY=simple
RETRIEVAL_K=8                # 每个检索源取 Top K
RERANK_TOP_K=3               # 重排序后保留 Top K
MULTI_QUERY_COUNT=3          # MultiQuery 生成变体数量

# ---------- 记忆系统 ----------
# 短期记忆类型: buffer | window | summary | vectorstore | entity
MEMORY_TYPE=buffer
MEMORY_WINDOW_SIZE=5

# 长期记忆系统（Episodic + Semantic + Working 三层）
LS_ENABLED=true
LS_EPISODIC_TOP_K=3
LS_SEMANTIC_TOP_K=3
LS_RECALL_TOTAL=5

# ---------- 文档切分 ----------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ---------- 缓存 ----------
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600      # 缓存有效期（秒）
CACHE_MAX_SIZE=1000          # 最大缓存条目

# ---------- Hugging Face ----------
# 避免下载模型时的限流警告，在 https://huggingface.co/settings/tokens 创建
HF_TOKEN=hf_your_token_here

# ---------- 运行时 ----------
USE_CUDA=true                # 是否使用 GPU 加速
DEBUG=false                  # 调试模式（输出更多日志）
SERVER_HOST=0.0.0.0
SERVER_PORT=7860